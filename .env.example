# ── Elasticsearch ──
ELASTIC_PASSWORD=your_elastic_password_here
KIBANA_PASSWORD=your_kibana_password_here
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ── Wazuh ──
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=your_wazuh_api_password_here

# ── VirusTotal (Phase 7) ──
VT_API_KEY=your_virustotal_api_key_here

# ── Groq API (Phase 6 — AI Agent, free) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Slack (Phase 8) ──
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ── Email (Phase 8) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email_here
SMTP_PASSWORD=your_email_app_password_here
ALERT_EMAIL_TO=soc-team@yourcompany.com

# ── AWS (Phase 2) ──
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_DEFAULT_REGION=us-east-1
