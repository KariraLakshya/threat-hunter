# ═══════════════════════════════════════════════════════════
#  Local Suricata Rules — Threat Hunter Phase 1
# ═══════════════════════════════════════════════════════════

# Test rule: alert on any ICMP (ping)
alert icmp any any -> $HOME_NET any (msg:"TEST - ICMP Ping Detected"; sid:1000001; rev:1;)

# SSH brute force: multiple SSH connection attempts
alert tcp any any -> $HOME_NET $SSH_PORTS (msg:"THREAT - Possible SSH Brute Force"; flow:to_server,established; threshold:type both, track by_src, count 5, seconds 60; sid:1000002; rev:1;)

# SMB lateral movement indicator
alert tcp any any -> $HOME_NET 445 (msg:"THREAT - SMB Connection to Internal Host (Lateral Movement Indicator)"; flow:to_server,established; sid:1000003; rev:1;)

# Large outbound data transfer (possible exfiltration)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"THREAT - Large Outbound Data Transfer (Possible Exfiltration)"; flow:to_server,established; dsize:>10000; threshold:type both, track by_src, count 50, seconds 300; sid:1000004; rev:1;)

# Suspicious outbound DNS query (long subdomain = possible C2 tunnel)
alert dns any any -> any any (msg:"THREAT - Suspiciously Long DNS Query (Possible DNS Tunnel)"; dns.query; content:"."; offset:50; sid:1000005; rev:1;)
