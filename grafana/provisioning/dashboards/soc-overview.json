{
  "uid": "soc-overview",
  "title": "SOC Overview",
  "tags": ["soc", "security"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Event Volume",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "*",
          "alias": "All Events",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": { "interval": "auto", "min_doc_count": "0" }
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Alert Counters",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["count"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "severity:critical OR severity:high",
          "alias": "High/Critical",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "1h" } }
          ]
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Auth Failures",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "event_type:failed_login OR event_type:brute_force",
          "alias": "Auth Failures",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto" } }
          ]
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cloud Activity",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "environment:aws OR environment:cloud",
          "alias": "Cloud Events",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto" } }
          ]
        }
      ]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Pipeline Health",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green",  "value": 80 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "*",
          "alias": "Indexed",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "5m" } }
          ]
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Network Anomalies",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 16 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "event_type:port_scan OR event_type:lateral_movement OR event_type:suspicious_connection",
          "alias": "Network Anomalies",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto" } }
          ]
        }
      ]
    }
  ]
}