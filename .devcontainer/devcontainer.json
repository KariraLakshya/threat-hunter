{
    "name": "Autonomous Threat Hunter",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "dockerDashComposeVersion": "v2"
        }
    },
    // Forward all service ports so you can access them from your browser
    "forwardPorts": [
        9200, // Elasticsearch
        5601, // Kibana
        5000, // Logstash TCP input
        6379, // Redis
        8000, // FastAPI backend
        8501, // Streamlit dashboard
        1514, // Wazuh agent UDP
        1515, // Wazuh agent TCP
        55000 // Wazuh API
    ],
    "portsAttributes": {
        "9200": {
            "label": "Elasticsearch",
            "onAutoForward": "silent"
        },
        "5601": {
            "label": "Kibana",
            "onAutoForward": "openBrowser"
        },
        "8000": {
            "label": "FastAPI",
            "onAutoForward": "silent"
        },
        "8501": {
            "label": "Dashboard",
            "onAutoForward": "openBrowser"
        }
    },
    // Runs once when the Codespace is first created
    "onCreateCommand": "pip install -r requirements.txt",
    // Runs every time the Codespace starts (creates + resumes)
    "postStartCommand": "docker compose up -d && echo '✅ Stack starting — ES takes ~60s to be ready'",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-azuretools.vscode-docker",
                "rangav.vscode-thunder-client"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    },
    // Resource recommendation: use 4-core / 16GB machine for ELK stack
    // Set in: github.com → repo Settings → Codespaces → Default machine type
    "hostRequirements": {
        "cpus": 4,
        "memory": "16gb",
        "storage": "32gb"
    }
}